# ──────────────────────────────────────────────────────────────────────────────
# GridMind AI — Environment Configuration Template (.env.example)
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to '.env' at the project root for local docker-compose testing,
# or set these variables individually in your cloud hosting provider (e.g. Railway).
# ──────────────────────────────────────────────────────────────────────────────

# ── 1. SERVICE PORTS (Dynamic Port Binding) ───────────────────────────────────
# Node.js gateway external port. Defaults to 5000 if not specified.
PORT=5000

# ── 2. GATEWAY CONFIGURATION (Node.js Service) ────────────────────────────────
# Point the gateway to the Python RAG Service endpoint.
# - For Local Native Running:  http://localhost:8000
# - For Local Docker-Compose: http://rag-service:8000 (resolves via compose networking)
# - For Railway Production:   http://<python-service-private-url>:8000 (use Railway private networking)
RAG_SERVICE_URL=http://localhost:8000

# ── 3. EXTERNAL APIS & LARGE LANGUAGE MODELS ─────────────────────────────────
# Groq API Key used by the Python RAG service for text generation (Llama-3.3-70b-versatile).
# Obtain from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Voyage AI API Key used by the Python RAG service for text embeddings (voyage-3.5).
# Obtain from https://dashboard.voyageai.com
VOYAGE_API_KEY=pa-your_voyage_api_key_here

# ── 4. CHROMADB CLOUD VECTOR STORE ───────────────────────────────────────────
# Authentication credentials for your managed ChromaDB Cloud instance.
# Do NOT touch retriever connection logic. Ensure these keys are copied exactly.
CHROMA_API_KEY=ck-your_chroma_api_key_here
CHROMA_TENANT=your_chromadb_tenant_id_here
CHROMA_DATABASE=chroma-rag

# ── 5. PYTHON INTERNAL CONFIGURATION ──────────────────────────────────────────
# Turn off anonymous telemetry for ChromaDB
ANONYMOUS_TELEMETRY=False
